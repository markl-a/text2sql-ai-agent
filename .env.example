# ── LLM 後端設定 ─────────────────────────────────────────────
# 後端擇一: "ollama" 或 "lmstudio"
LLM_BACKEND=ollama

# 模型名稱。
# 注意: 試題寫的 "gemma4:e4b" 在 Ollama 沒有對應 tag,
# 實際對應 Gemma 3n 的 gemma3n:e4b(詳見 docs/architecture.md)。
LLM_MODEL=gemma3n:e4b

# Ollama 端點(LLM_BACKEND=ollama 時使用)
OLLAMA_BASE_URL=http://localhost:11434

# LM Studio 端點(LLM_BACKEND=lmstudio 時使用,OpenAI 相容)
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LMSTUDIO_API_KEY=lm-studio

# 生成參數
LLM_TEMPERATURE=0
LLM_NUM_CTX=8192

# ── 資料庫 ───────────────────────────────────────────────────
DB_PATH=data/supermarket.db
CSV_PATH=data/SuperMarket Analysis.csv
TABLE_NAME=sales

# SQL 執行安全上限
MAX_RESULT_ROWS=1000
SQL_TIMEOUT_SECONDS=10
MAX_RETRIES=3

# ── LangSmith(Observability)─────────────────────────────────
# 註冊免費帳號取得 key: https://smith.langchain.com/
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=text2sql-agent
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
